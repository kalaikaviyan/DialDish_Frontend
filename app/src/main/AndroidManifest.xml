<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:allowBackup="true"
        android:usesCleartextTraffic="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Dishdial">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.Dishdial">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".LoginActivity"
            android:exported="false" />

        <activity
            android:name=".SignupActivity"
            android:exported="false" />

        <activity
            android:name=".owner.OHomeActivity"
            android:exported="false" />

        <activity
            android:name=".owner.OAddDeliveryManActivity"
            android:exported="false" />

        <activity
            android:name=".owner.OOrdersActivity"
            android:exported="false" />

        <activity
            android:name=".owner.OMenuActivity"
            android:exported="false" />

        <activity
            android:name=".owner.OProfileActivity"
            android:exported="false" />

        <activity
            android:name=".owner.OSettingsActivity"
            android:exported="false" />

        <activity android:name=".owner.OHowToUseActivity" android:exported="false" />
        <activity android:name=".owner.OAppFeaturesActivity" android:exported="false" />
        <activity android:name=".owner.OPrivacyPolicyActivity" android:exported="false" />

        <activity
            android:name=".owner.OManageStaffActivity"
            android:exported="false" />

        <activity
            android:name=".owner.OChangePasswordActivity"
            android:exported="false" />
    </application>

</manifest>